#!/usr/bin/env bash
set -euo pipefail

readonly TODAY="$(date +'%F')"
readonly FILE="public/sitemap.xml"

if sed --version >/dev/null 2>&1; then
  # GNU sed (Linux)
  sed -E -i "s#(<lastmod>)[0-9]{4}-[0-9]{2}-[0-9]{2}(</lastmod>)#\1${TODAY}\2#g" "$FILE"
else
  # BSD sed (macOS)
  sed -E -i '' "s#(<lastmod>)[0-9]{4}-[0-9]{2}-[0-9]{2}(</lastmod>)#\1${TODAY}\2#g" "$FILE"
fi

echo "Updated lastmod in $FILE to $TODAY"
